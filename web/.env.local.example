# FastAPI backend — set to your Render service URL in production
# e.g. https://nba-ev-api.onrender.com
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Full public URL of this app — used for OG image metadataBase
# Set to your Vercel URL in production, e.g. https://nba-ev.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Vercel injects this automatically in production. Set locally only if you want
# to test the /api/keepalive auth check (leave unset for unrestricted local access).
# CRON_SECRET=your_cron_secret_here
