# Local dev: matches docker-compose.yml defaults
DATABASE_URL=postgresql://postgres:password@localhost:5432/nba_ev

# The Odds API — the-odds-api.com (free tier: 500 req/month)
ODDS_API_KEY=your_odds_api_key_here

# Telegram — @BotFather for token, @userinfobot for chat ID
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# CORS — set to your Vercel URL in prod
FRONTEND_ORIGIN=http://localhost:3000

# Edge detection threshold (default 3%)
EV_THRESHOLD=0.03

LOG_LEVEL=INFO
